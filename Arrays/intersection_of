class Solution:
    def frequency(self,arr):
        freq={}
        for i in arr:
            if i  in freq:
                freq[i] += 1
            else:
                freq[i] = 1
        return freq

x=Solution()
print(x.frequency([1,2,2,1,3,4,3]))

